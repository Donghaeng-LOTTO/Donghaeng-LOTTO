# =========================
# Node.js & Next.js
# =========================
# 프로젝트 내 모든 의존성 및 캐시 폴더 강제 차단 (중요)
**/node_modules/
**/.next/
**/out/
**/.vercel/

# 프론트엔드 환경 변수 파일
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# 패키지 매니저 로그
*.log*
**/npm-debug.log*
**/yarn-debug.log*
**/pnpm-debug.log*

# =========================
# Python & 가상환경
# =========================
**/__pycache__/
**/*.py[cod]
**/*$py.class

# 가상환경 폴더 전체 차단 (루트 및 하위 파이프라인 내부 포함)
.venv/
**/venv/
**/env/

# 파이썬 빌드 파일
**/build/
**/dist/
**/*.egg-info/

# =========================
# 환경 변수 및 공통 설정
# =========================
.env
.env.*
!.env.example

# =========================
# 데이터 및 크롤링 파일 (경로 고도화)
# =========================
**/*.csv
**/*.tsv
**/*.xlsx
**/*.xls
**/*.parquet
**/*.pkl
**/*.pickle
**/*.feather

# 하위 파이프라인 폴더 내 데이터 저장소 차단
# **/data/raw/
# **/data/processed/
# **/data/external/

# data 폴더 안의 실제 파일들은 기본적으로 차단
**/data/raw/**
**/data/processed/**
**/data/external/**

# 단, 폴더 구조 탐색은 허용
!**/data/raw/**/
!**/data/processed/**/
!**/data/external/**/

# 구조 유지를 위한 파일은 예외 허용
# !**/data/raw/.gitkeep
# !**/data/processed/.gitkeep
# !**/data/external/.gitkeep

!**/data/processed/.gitkeep
!**/data/raw/naver_record/.gitkeep
!**/data/raw/naver_relay/.gitkeep
!**/data/raw/naver_schedule/.gitkeep
!**/data/external/kaggle/.gitkeep

# =========================
# JSON 처리 및 설정 파일 예외
# =========================
# 데이터용 JSON 위주로 차단하되 설정 파일은 엄격하게 살림
**/raw_*.json
**/*.jsonl

# 프로젝트 설정에 필수적인 json 파일들은 무조건 추적
!**/package.json
!**/package-lock.json
!**/tsconfig.json
!**/pyproject.toml
!**/config/*.json

# =========================
# 개발 툴 및 시스템 파일
# =========================
.DS_Store
Thumbs.db
**/.vscode/
**/.idea/
**/.ipynb_checkpoints/

# =========================
# 대용량 분석 결과물 및 모델 가중치
# =========================
**/checkpoints/
**/outputs/
**/reports/
**/artifacts/

**/*.joblib
**/*.h5
**/*.keras
**/*.pt
**/*.pth
**/*.onnx

**/*.pdf
**/*.m4a

**/analysis/*.png